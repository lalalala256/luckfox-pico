# Kernel config fragment for Luckfox Pico Mini B
# Disables camera, ISP, NPU, VEPU, RVE, DVBM, RGA, WiFi drivers
# that are not present on this board

# Disable camera sensor drivers
# CONFIG_VIDEO_SC3336 is not set
# CONFIG_VIDEO_SC4336 is not set
# CONFIG_VIDEO_SC530AI is not set
# CONFIG_VIDEO_IMX415 is not set
# CONFIG_VIDEO_MIS5001 is not set
# CONFIG_VIDEO_MIA1321 is not set
# CONFIG_VIDEO_RK_IRCUT is not set

# Disable Rockchip camera/ISP framework
# CONFIG_VIDEO_ROCKCHIP_CIF is not set
# CONFIG_VIDEO_ROCKCHIP_ISP is not set

# Disable MIPI CSI DPHY
# CONFIG_PHY_ROCKCHIP_CSI2_DPHY is not set

# Disable NPU (AI accelerator)
# CONFIG_ROCKCHIP_RKNPU is not set
# CONFIG_ROCKCHIP_RKNPU_PROC_FS is not set
# CONFIG_ROCKCHIP_RKNPU_DMA_HEAP is not set

# Disable RVE (video encoder post-processor)
# CONFIG_ROCKCHIP_RVE is not set
# CONFIG_ROCKCHIP_RVE_PROC_FS is not set

# Disable DVBM (display video buffer manager)
# CONFIG_ROCKCHIP_DVBM is not set

# Disable RGA (graphics accelerator)
# CONFIG_ROCKCHIP_MULTI_RGA is not set
# CONFIG_ROCKCHIP_RGA_PROC_FS is not set

# Disable RTL8723BS WiFi (Mini B has no WiFi)
# CONFIG_RTL8723BS is not set

# Disable WiFi build module support
# CONFIG_WIFI_BUILD_MODULE is not set
